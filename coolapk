#!name=酷安
#!desc=去广告
#!category=广告
[Rule]
#数字联盟
DOMAIN-SUFFIX,shuzilm.cn,REJECT,pre-matching
[Body Rewrite]
#热搜
http-response-jq https:\/\/api\.coolapk\.com\/v6\/search? 'def filterEntityTemplate: .entityTemplate != "hotSearch" and .entityTemplate != "searchHotListCard"; .data |= map(select(filterEntityTemplate))'
#开屏广告
https:\/\/api\.coolapk\.com\/v6\/main\/init ".data |= del(.extraData)"
#首页广场，推荐官
http-response-jq https:\/\/api\.coolapk\.com\/v6\/main\/indexV8 '.data |=map(if has("entities") then .entities |= del(.[] | select(.title == "推荐官")) else . end    | select(.lastupdate != 1733907830) )'
[MITM]
hostname = %APPEND% api.coolapk.com
