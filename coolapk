#!name=酷安
#!desc=去广告
#!category=广告
[Map Local]
^https:\/\/api\.coolapk\.com\/v6\/search\?.*type=hotSearch data-type=text data="{}" status-code=200
[Body Rewrite]
#首页广场
http-response-jq https:\/\/api\.coolapk\.com\/v6\/main\/indexV8 ".data |= map(select(.title != "广场" or .entities == null))"
#帖子推广
http-response-jq https:\/\/api\.coolapk\.com\/v6\/feed\/detail "delpaths([["data", "include_goods"],["data", "detailSponsorCard"]])"
[MITM]
hostname = %APPEND% api.coolapk.com
